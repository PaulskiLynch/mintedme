generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String
  username      String   @unique
  avatarUrl     String?
  tagline       String?
  balance       Decimal  @default(1000000.00) @db.Decimal(12, 2)
  lockedBalance Decimal  @default(0)          @db.Decimal(12, 2)
  mintValue     Decimal  @default(0)          @db.Decimal(12, 2)
  netWorth      Decimal  @default(0)          @db.Decimal(12, 2)
  prestigeScore Decimal  @default(0)          @db.Decimal(10, 2)
  isEstablished Boolean  @default(false)
  isAdmin       Boolean  @default(false)
  isFrozen      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  ownedEditions      ItemEdition[]      @relation("CurrentOwner")
  offersAsBuyer      Offer[]            @relation("OfferBuyer")
  transactionsFrom   Transaction[]      @relation("TransactionFrom")
  transactionsTo     Transaction[]      @relation("TransactionTo")
  feedEventsActed    FeedEvent[]        @relation("FeedActor")
  feedEventsTargeted FeedEvent[]        @relation("FeedTarget")
  notifications      Notification[]
  watchedItems       WatchedItem[]
  createdItems       Item[]             @relation("ItemCreator")
  submissions        CreatorSubmission[]
  ownerships         Ownership[]
  interests          Json?
  lastSeenAt         DateTime?

  auctionsAsSeller   Auction[]          @relation("AuctionSeller")
  auctionWins        Auction[]          @relation("AuctionWinner")
  bids               Bid[]
  auctionMessages    AuctionMessage[]
  followers          Follow[]           @relation("Following")
  following          Follow[]           @relation("Follower")
  feedLikes          FeedLike[]
  feedComments       FeedComment[]
  reports            Report[]

  @@map("users")
}

model Item {
  id               String   @id @default(uuid())
  name             String                             // fictional MilliBux name
  inspirationName  String?                            // real-world inspiration (admin reference)
  description      String?
  category         String   @default("cars")
  rarityTier       String                             // Common | Rare | Exotic | Legendary | Mythic
  imageUrl         String?
  totalSupply      Int
  benchmarkPrice   Decimal  @db.Decimal(12, 2)        // internal/admin-only
  minimumBid       Decimal  @db.Decimal(12, 2)        // public (10% of benchmark)
  horsepower       Int?                                 // hp
  topSpeed         Int?                                 // km/h
  zeroToHundred    Decimal? @db.Decimal(4, 1)           // seconds
  hasIncome        Boolean  @default(false)
  incomePerView    Decimal? @db.Decimal(10, 2)
  creatorId        String?
  isOfficial       Boolean  @default(true)
  isApproved       Boolean  @default(true)
  isFrozen         Boolean  @default(false)
  itemStatus       String   @default("active")        // draft | active | retired
  createdAt        DateTime @default(now())

  creator  User?         @relation("ItemCreator", fields: [creatorId], references: [id])
  editions ItemEdition[]

  @@map("items")
}

model ItemEdition {
  id             String    @id @default(uuid())
  itemId         String
  editionNumber  Int
  currentOwnerId String?
  lastSalePrice  Decimal?  @db.Decimal(12, 2)
  lastSaleDate   DateTime?
  highestOffer   Decimal?  @db.Decimal(12, 2)
  isListed       Boolean   @default(false)
  listedPrice    Decimal?  @db.Decimal(12, 2)
  isInAuction    Boolean   @default(false)
  isFrozen       Boolean   @default(false)
  lastIncomeAt   DateTime?
  createdAt      DateTime  @default(now())

  item         Item           @relation(fields: [itemId], references: [id], onDelete: Cascade)
  currentOwner User?          @relation("CurrentOwner", fields: [currentOwnerId], references: [id])
  offers       Offer[]
  ownerships   Ownership[]
  feedEvents   FeedEvent[]
  watchedBy    WatchedItem[]
  transactions Transaction[]
  auctions     Auction[]
  priceHistory PriceHistory[]
  reports      Report[]
  views        ItemView[]

  @@unique([itemId, editionNumber])
  @@map("item_editions")
}

model Ownership {
  id            String    @id @default(uuid())
  editionId     String
  ownerId       String
  purchasePrice Decimal?  @db.Decimal(12, 2)
  purchaseDate  DateTime  @default(now())
  transferType  String    // buy, auction_win, offer_accept, admin
  endedAt       DateTime?

  edition ItemEdition @relation(fields: [editionId], references: [id], onDelete: Cascade)
  owner   User        @relation(fields: [ownerId], references: [id])

  @@map("ownerships")
}

model Offer {
  id              String   @id @default(uuid())
  editionId       String
  buyerId         String
  amount          Decimal  @db.Decimal(12, 2)
  status          String   @default("pending") // pending, accepted, declined, expired, countered
  expiresAt       DateTime
  isFundsReserved Boolean  @default(true)
  counterOfferId  String?  @unique
  message         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  edition      ItemEdition  @relation(fields: [editionId], references: [id])
  buyer        User         @relation("OfferBuyer", fields: [buyerId], references: [id])
  counterOffer Offer?       @relation("CounterChain", fields: [counterOfferId], references: [id])
  parentOffer  Offer?       @relation("CounterChain")
  transaction  Transaction?

  @@map("offers")
}

model Transaction {
  id          String   @id @default(uuid())
  fromUserId  String?
  toUserId    String?
  editionId   String?
  offerId     String?  @unique
  auctionId   String?
  amount      Decimal  @db.Decimal(12, 2)
  type        String   // purchase, sale, auction_win, income, refund
  description String?
  createdAt   DateTime @default(now())

  fromUser User?        @relation("TransactionFrom", fields: [fromUserId], references: [id])
  toUser   User?        @relation("TransactionTo",   fields: [toUserId],   references: [id])
  edition  ItemEdition? @relation(fields: [editionId], references: [id])
  offer    Offer?       @relation(fields: [offerId],   references: [id])

  @@map("transactions")
}

model Auction {
  id                 String   @id @default(uuid())
  editionId          String
  sellerId           String
  minimumBid         Decimal  @db.Decimal(12, 2)   // public
  benchmarkPrice     Decimal  @db.Decimal(12, 2)   // admin-only
  rarityTier         String                         // denormalised for settlement logic
  currentBid         Decimal? @db.Decimal(12, 2)   // internal — highest bid so far
  currentWinnerId    String?                        // internal — resolved at settlement
  winningBid         Decimal? @db.Decimal(12, 2)   // set at settlement
  luckyUndervalueWin Boolean  @default(false)
  status             String   @default("scheduled") // scheduled | active | ended | settled
  startsAt           DateTime?
  endsAt             DateTime
  createdAt          DateTime @default(now())

  edition       ItemEdition      @relation(fields: [editionId],       references: [id])
  seller        User             @relation("AuctionSeller",  fields: [sellerId],         references: [id])
  currentWinner User?            @relation("AuctionWinner",  fields: [currentWinnerId],  references: [id])
  bids          Bid[]
  messages      AuctionMessage[]

  @@map("auctions")
}

model Bid {
  id        String   @id @default(uuid())
  auctionId String
  userId    String
  amount    Decimal  @db.Decimal(12, 2)
  status    String   @default("active") // active | won | lost | refunded | invalid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auction Auction @relation(fields: [auctionId], references: [id])
  user    User    @relation(fields: [userId],    references: [id])

  @@unique([auctionId, userId])   // one sealed bid per user per auction
  @@map("bids")
}

model FeedEvent {
  id           String   @id @default(uuid())
  eventType    String   // buy, sell, offer, accept, auction_start, auction_end, achievement, income, market_event, post
  userId       String?
  targetUserId String?
  editionId    String?
  amount       Decimal? @db.Decimal(12, 2)
  metadata     Json?
  isVisible    Boolean  @default(true)
  createdAt    DateTime @default(now())

  user       User?        @relation("FeedActor",  fields: [userId],       references: [id])
  targetUser User?        @relation("FeedTarget", fields: [targetUserId], references: [id])
  edition    ItemEdition? @relation(fields: [editionId], references: [id])
  likes      FeedLike[]
  comments   FeedComment[]

  @@map("feed_events")
}

model Notification {
  id              String   @id @default(uuid())
  userId          String
  type            String
  message         String
  relatedEntityId String?
  isRead          Boolean  @default(false)
  actionUrl       String?
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model WatchedItem {
  userId    String
  editionId String
  createdAt DateTime @default(now())

  user    User        @relation(fields: [userId],    references: [id], onDelete: Cascade)
  edition ItemEdition @relation(fields: [editionId], references: [id], onDelete: Cascade)

  @@id([userId, editionId])
  @@map("watched_items")
}

model CreatorSubmission {
  id                   String    @id @default(uuid())
  creatorId            String
  itemName             String
  category             String
  imageUrl             String
  description          String?
  requestedPrice       Decimal?  @db.Decimal(12, 2)
  requestedEditionSize Int?
  status               String    @default("pending") // pending, approved, rejected
  adminNotes           String?
  reviewedBy           String?
  createdAt            DateTime  @default(now())
  reviewedAt           DateTime?

  creator User @relation(fields: [creatorId], references: [id])

  @@map("creator_submissions")
}

model Report {
  id          String    @id @default(uuid())
  reporterId  String
  editionId   String?
  reason      String
  description String?
  status      String    @default("pending")
  reviewedBy  String?
  createdAt   DateTime  @default(now())
  reviewedAt  DateTime?

  reporter User         @relation(fields: [reporterId], references: [id])
  edition  ItemEdition? @relation(fields: [editionId], references: [id])

  @@map("reports")
}

model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Follower",  fields: [followerId],  references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@map("follows")
}

model FeedLike {
  userId      String
  feedEventId String
  type        String   @default("like")
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId],      references: [id], onDelete: Cascade)
  feedEvent FeedEvent @relation(fields: [feedEventId], references: [id], onDelete: Cascade)

  @@id([userId, feedEventId])
  @@map("feed_likes")
}

model FeedComment {
  id          String   @id @default(uuid())
  feedEventId String
  userId      String
  message     String   @db.VarChar(500)
  createdAt   DateTime @default(now())

  feedEvent FeedEvent @relation(fields: [feedEventId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId],      references: [id])

  @@map("feed_comments")
}

model AuctionMessage {
  id        String   @id @default(uuid())
  auctionId String
  userId    String
  message   String   @db.VarChar(500)
  createdAt DateTime @default(now())

  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId],    references: [id])

  @@map("auction_messages")
}

model PriceHistory {
  id              String   @id @default(uuid())
  editionId       String
  price           Decimal  @db.Decimal(12, 2)
  transactionType String   // sale, offer, auction
  recordedAt      DateTime @default(now())

  edition ItemEdition @relation(fields: [editionId], references: [id], onDelete: Cascade)

  @@map("price_history")
}

model ItemView {
  id        String   @id @default(uuid())
  editionId String
  userId    String?
  createdAt DateTime @default(now())

  edition ItemEdition @relation(fields: [editionId], references: [id], onDelete: Cascade)

  @@map("item_views")
}
